import time
from pyngrok import ngrok
import os

# 1. Configuration
NGROK_TOKEN = "3D7DPWdOrmeJCvePwE6AvZitDQL_Uhmv7TGyTQvrNBXm1hCm"
PORT = 9000

# 2. Cleanup
print("1️⃣ Cleaning up old sessions...")
!fuser -k {PORT}/tcp || true
ngrok.set_auth_token(NGROK_TOKEN)

# 3. Start Public Tunnel (This is usually where it hangs)
print("2️⃣ Connecting to Ngrok... (Please wait 10 seconds)")
try:
    # Force kill any old ngrok processes
    !pkill ngrok || true
    time.sleep(2)
    public_url = ngrok.connect(PORT).public_url
    print(f"✅ NGROK CONNECTED: {public_url}")
except Exception as e:
    print(f"❌ NGROK FAILED: {e}")
    public_url = "FAILED"

# 4. Start Server in Background
if public_url != "FAILED":
    print("3️⃣ Starting OCR Engine in Background...")
    # We use -u for unbuffered output so we can see logs instantly
    !nohup python -u -m uvicorn app.main:app --host 0.0.0.0 --port {PORT} > server.log 2>&1 &
    
    print("4️⃣ Waiting for startup (15 seconds)...")
    time.sleep(15)
    
    print("\n" + "="*50)
    print("📜 LATEST SERVER LOGS:")
    !tail -n 10 server.log
    print("="*50 + "\n")
    
    print(f"🚀 FINAL PUBLIC URL: {public_url}")
else:
    print("🛑 Script stopped because Ngrok failed.")
